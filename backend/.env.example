NODE_ENV=development
PORT=4000

MONGODB_URI=mongodb://localhost:27017/managesociety

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=15m
