GLOBAL_RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=20
LOGIN_RATE_LIMIT_MAX=10
PAGINATION_DEFAULT_LIMIT=25
PAGINATION_MAX_LIMIT=100
ADMIN_IP_WHITELIST=

SUPERADMIN_BOOTSTRAP_KEY=dev_only_change_me

S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
